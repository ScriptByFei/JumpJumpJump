import Phaser from 'phaser';
import { PLATFORM_WIDTH, PLATFORM_HEIGHT } from '../config';

export type PlatformType = 'normal' | 'moving' | 'fragile';

export class Platform extends Phaser.Physics.Arcade.Sprite {
  public platformType: PlatformType = 'normal';
  public isMoving = false;
  public isFragile = false;
  public alive = true;

  private moveDir = 1;
  private moveSpeed = 120;
  private moveRangeMin = PLATFORM_WIDTH / 2;
  private moveRangeMax = 330;

  // Fragile: shake before break
  private shakeTimer = 0;
  private readonly SHAKE_DURATION = 400;
  private touchedByPlayer = false;

  constructor(
    scene: Phaser.Scene,
    x: number,
    y: number,
    texture = 'platform',
    platformType: PlatformType = 'normal',
  ) {
    super(scene, x, y, texture);
    scene.add.existing(this);
    scene.physics.add.existing(this);

    this.platformType = platformType;
    this.isMoving = platformType === 'moving';
    this.isFragile = platformType === 'fragile';

    // Use a STATIC body — doesn't fall, doesn't get pushed
    const body = this.body as Phaser.Physics.Arcade.StaticBody;
    body.setSize(PLATFORM_WIDTH, PLATFORM_HEIGHT);
    body.updateFromGameObject();

    this.updateTextureForType();
  }

  private updateTextureForType(): void {
    // Texture is set by the key passed in; fragile/moving are separate textures
    // This is for future use if we want to retint dynamically
    if (this.isFragile) {
      this.setTint(0xff9999);
    }
  }

  // Called by player collision
  onPlayerLand(): void {
    if (this.isFragile && !this.touchedByPlayer) {
      this.touchedByPlayer = true;
      this.shakeTimer = this.SHAKE_DURATION;
    }
  }

  update(delta: number): void {
    // Moving platform movement
    if (this.isMoving && this.alive) {
      this.x += this.moveSpeed * this.moveDir;
      if (this.x >= this.moveRangeMax) {
        this.moveDir = -1;
      } else if (this.x <= this.moveRangeMin) {
        this.moveDir = 1;
      }
      // Sync physics body with sprite
      (this.body as Phaser.Physics.Arcade.StaticBody).updateFromGameObject();
    }

    // Fragile shake
    if (this.isFragile && this.touchedByPlayer && this.alive) {
      this.shakeTimer -= delta;
      if (this.shakeTimer > 0) {
        this.setX(this.x + (Math.random() - 0.5) * 4);
      } else {
        this.break();
      }
    }
  }

  private break(): void {
    if (!this.alive) return;
    this.alive = false;

    // Visual break effect — small particles
    const particles = this.scene.add.particles(this.x, this.y, 'platform', {
      speed: { min: 30, max: 100 },
      angle: { min: 0, max: 360 },
      scale: { start: 0.5, end: 0 },
      lifespan: 400,
      gravityY: 300,
      quantity: 6,
    });
    this.scene.time.delayedCall(500, () => particles.destroy());

    this.destroy();
  }

  destroy(): void {
    if (!this.alive) return;
    this.alive = false;
    super.destroy();
  }
}
