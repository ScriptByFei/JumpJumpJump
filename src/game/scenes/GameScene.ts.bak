import Phaser from 'phaser';
import { Player } from '../objects/Player';
import { Platform } from '../objects/Platform';
import { PlatformSpawner } from '../systems/PlatformSpawner';
import { ScoreSystem } from '../systems/ScoreSystem';
import {
  GAME_WIDTH,
  GAME_HEIGHT,
  COLORS,
  CAMERA_OFFSET_Y,
  CAMERA_LERP_X,
  CAMERA_LERP_Y,
  DEATH_ZONE_BELOW_CAMERA,
} from '../config';

export class GameScene extends Phaser.Scene {
  private player!: Player;
  private platformSpawner!: PlatformSpawner;
  private scoreSystem!: ScoreSystem;
  private isGameOver = false;
  private currentDifficulty = 1;
  private lastDifficultyMilestone = 0;

  private bgLayer1!: Phaser.GameObjects.TileSprite;
  private bgLayer2!: Phaser.GameObjects.TileSprite;

  constructor() {
    super({ key: 'GameScene' });
  }

  create(): void {
    this.cameras.main.setBackgroundColor(COLORS.background);
    this.isGameOver = false;
    this.currentDifficulty = 1;
    this.lastDifficultyMilestone = 0;

    // Physics world — tall
    this.physics.world.setBounds(0, -5_000_000, GAME_WIDTH, 10_000_000);

    // Camera
    this.cameras.main.setFollowOffset(0, CAMERA_OFFSET_Y);
    this.cameras.main.setBounds(0, -5_000_000, GAME_WIDTH, 10_000_000);

    this.createBackground();

    const startY = 560;
    this.platformSpawner = new PlatformSpawner(this, startY);
    this.scoreSystem = new ScoreSystem(this, startY);

    // Player
    this.player = new Player(this, GAME_WIDTH / 2, startY - 50);

    // Collider with the Group — stays dynamic as platforms are added/removed
    this.physics.add.collider(
      this.player,
      this.platformSpawner.getGroup(),
      (playerObj, platformObj) => {
        const player = playerObj as Player;
        const platform = platformObj as Platform;
        const body = player.body as Phaser.Physics.Arcade.Body;

        // ONLY jump when:
        // 1. Player is falling (velocity.y > 0)
        // 2. Player's bottom is at or near platform top (touching.down = landing detected)
        // 3. Jump cooldown allows it
        const isLanding = body.touching.down || body.blocked.down;
        if (isLanding && player.isFalling() && player.canJumpNow()) {
          player.jump();
          platform.onPlayerLand();
          player.triggerLandingEffect();
        }
      }
    );

    this.cameras.main.startFollow(this.player, false, CAMERA_LERP_X, CAMERA_LERP_Y);
  }

  private createBackground(): void {
    this.bgLayer1 = this.add.tileSprite(0, 0, GAME_WIDTH, GAME_HEIGHT, '__bg1')
      .setOrigin(0, 0)
      .setScrollFactor(0)
      .setAlpha(0.15)
      .setTint(0x4ecdc4);

    this.bgLayer2 = this.add.tileSprite(0, 0, GAME_WIDTH, GAME_HEIGHT, '__bg2')
      .setOrigin(0, 0)
      .setScrollFactor(0)
      .setAlpha(0.1)
      .setTint(0xfeca57);
  }

  update(_time: number, delta: number): void {
    if (this.isGameOver) return;

    const camera = this.cameras.main;
    const cameraTopY = camera.scrollY;

    this.player.update(delta);

    // Update moving/fragile platforms
    this.platformSpawner.getGroup().getChildren().forEach((child) => {
      (child as Platform).update(delta);
    });

    // Spawn and cull
    this.platformSpawner.spawnAboveCamera(cameraTopY);
    this.platformSpawner.removeBelowCamera(cameraTopY + GAME_HEIGHT);

    // Score
    this.scoreSystem.update(this.player.y);

    // Difficulty
    this.updateDifficulty();

    // Parallax
    this.bgLayer1.setTilePosition(0, cameraTopY * 0.05);
    this.bgLayer2.setTilePosition(0, cameraTopY * 0.15);

    // Game over check
    const deathLine = cameraTopY + GAME_HEIGHT + DEATH_ZONE_BELOW_CAMERA;
    if (this.player.y > deathLine) {
      this.triggerGameOver();
    }
  }

  private updateDifficulty(): void {
    const height = this.scoreSystem.getHeightClimbed();
    const milestone = Math.floor(height / 500);
    if (milestone > this.lastDifficultyMilestone) {
      this.lastDifficultyMilestone = milestone;
      this.currentDifficulty = Math.min(1 + milestone, 10);
      this.platformSpawner.setDifficulty(this.currentDifficulty);
    }
  }

  private triggerGameOver(): void {
    if (this.isGameOver) return;
    this.isGameOver = true;
    this.scoreSystem.saveHighScore();

    this.scene.start('GameOverScene', {
      score: this.scoreSystem.getScore(),
      highScore: this.scoreSystem.getHighScore(),
      height: this.scoreSystem.getHeightClimbed(),
    });
  }
}
